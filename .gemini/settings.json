{
  "hooks": {
    "AfterTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "name": "sync-check-after-tool",
            "type": "command",
            "command": "node .gemini/hooks/sync-check.cjs AfterTool"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "sync-check-before-agent",
            "type": "command",
            "command": "node .gemini/hooks/sync-check.cjs BeforeAgent"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "sync-check-after-agent",
            "type": "command",
            "command": "node .gemini/hooks/sync-check.cjs AfterAgent"
          }
        ]
      }
    ]
  }
}
